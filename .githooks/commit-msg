#!/usr/bin/env bash
# Enforce Conventional Commits: type(scope?): description
# Types: feat fix docs style refactor perf test chore ci revert build

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits and fixup/squash commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge |fixup! |squash! )"; then
    exit 0
fi

PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert|build)(\([a-z0-9/_-]+\))?(!)?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌  Commit message does not follow Conventional Commits format."
    echo ""
    echo "    Expected: type(scope): description"
    echo "    Example:  feat(points): add adjust endpoint"
    echo ""
    echo "    Allowed types: feat fix docs style refactor perf test chore ci revert build"
    echo ""
    echo "    Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi

exit 0
