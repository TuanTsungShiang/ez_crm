APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ez-crm.local

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ez_crm
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dev 建議走 Mailtrap Email Testing Sandbox（免費,攔截測試信)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ez-crm.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# OAuth providers（於 Google Cloud Console / GitHub Developer Settings 申請)
# Redirect URI 要用 http://localhost:8080/... 因為 Google 不接受 .local TLD
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/github/callback

# ECPay (綠界) 金流整合（Phase 2.3 L1 — 接收付款 webhook）
# 測試環境使用 ECPay 公開 sandbox 憑證（免申請）
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_ENV=stage
# 正式環境請改為你的 Server URL（ECPay 需能公開 POST 到這個網址）
ECPAY_RETURN_URL=https://crm.example.com/api/v1/webhooks/ecpay/payment
ECPAY_CLIENT_BACK_URL=https://crm.example.com/orders/result
# IP 白名單（production 才啟用，逗號分隔，支援 CIDR）— 請定期查閱 ECPay 最新文件更新
# ECPAY_IP_WHITELIST=203.66.91.31,203.66.91.32,203.66.94.98,103.52.180.0/22

# LINE / Discord 待 Phase 4.2 / 4.3 實作
# LINE_CLIENT_ID=
# LINE_CLIENT_SECRET=
# LINE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/line/callback
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/discord/callback
